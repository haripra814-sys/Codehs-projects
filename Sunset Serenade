<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Sunset Serenade</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .jumbotron {
      background: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e') no-repeat center center;
      background-size: cover;
      color: white;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-shadow: 2px 2px 8px rgba(0,0,0,0.7);
    }

    .jumbotron .container {
      text-align: center;
      background-color: rgba(0,0,0,0.5);
      padding: 2rem;
      border-radius: 1rem;
    }

    .btn-explore {
      margin-top: 1.5rem;
    }
  </style>
</head>
<body>

  <!-- Jumbotron Section -->
  <section class="jumbotron">
    <div class="container">
      <h1 class="display-3">Sunset Serenade</h1>
      <p class="lead">Join us for an unforgettable evening of live music, dancing, and stunning sunset views.</p>
      <h4 class="mb-4">📅 September 21, 2025 | 6:00 PM - 10:00 PM</h4>
      <a href="#details" class="btn btn-warning btn-lg btn-explore">Explore More</a>
    </div>
  </section>

  <!-- Event Details Section -->
  <section id="details" class="container my-5">
    <div class="text-center">
      <h2>Event Highlights</h2>
      <p>Enjoy performances by local artists, gourmet food, and a sunset backdrop that sets the mood for magic.</p>
    </div>
    <!-- Add more content here if needed -->
  </section>

  <!-- Bootstrap JS (optional, for interactive components) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
