<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Age Classifier – Discover Your Life Stage</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: linear-gradient(120deg, #e0f7fa, #ffe0f0);
      font-family: 'Segoe UI', sans-serif;
    }
    .container {
      max-width: 600px;
      margin-top: 80px;
    }
    .magic-box {
      background: #fff;
      border-radius: 15px;
      padding: 2rem;
      box-shadow: 0 0 20px rgba(0,0,0,0.1);
      text-align: center;
    }
    .result {
      margin-top: 1.5rem;
      padding: 1rem;
      border-radius: 8px;
      background-color: #fef9f5;
      border: 1px solid #f2ddd5;
    }
  </style>
</head>
<body>

  <div class="container">
    <div class="magic-box">
      <h2 class="mb-4">🔮 What Age Realm Do You Belong To?</h2>
      <p class="mb-3">Enter your age and uncover the magic of your life stage.</p>

      <div class="input-group mb-3">
        <input type="number" id="ageInput" class="form-control" placeholder="Enter your age..." min="0" />
        <button class="btn btn-primary" onclick="classifyAge()">Reveal ✨</button>
      </div>

      <div id="result" class="result d-none"></div>
    </div>
  </div>

  <!-- Script for Age Classification -->
  <script>
    function classifyAge() {
      const age = parseInt(document.getElementById('ageInput').value);
      const resultBox = document.getElementById('result');

      let group = '';
      let insight = '';

      if (isNaN(age) || age < 0) {
        resultBox.innerHTML = "🚫 Please enter a valid positive age.";
      } else if (age <= 12) {
        group = 'Child';
        insight = 'You see the world with wonder and imagination. Keep dreaming big!';
      } else if (age <= 19) {
        group = 'Teenager';
        insight = 'A time of adventure and self-discovery. Explore boldly!';
      } else if (age <= 35) {
        group = 'Young Adult';
        insight = 'You’re shaping your destiny. The world is your canvas!';
      } else if (age <= 55) {
        group = 'Adult';
        insight = 'With wisdom and strength, you build and inspire.';
      } else {
        group = 'Senior';
        insight = 'A sage of stories and serenity. Your journey is a treasure trove.';
      }

      resultBox.classList.remove('d-none');
      resultBox.innerHTML = `
        <h4>You belong to the <strong>${group}</strong> age group 🌟</h4>
        <p>${insight}</p>
      `;
    }
  </script>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
